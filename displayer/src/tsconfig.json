{
    "extends": "../../tsconfig_browser.jsonc",
    "include": ["**/*.ts", "**/*.vue"],
    "compilerOptions": {
        "types": ["lodash", "offscreencanvas"],
        "paths": {
            "@/*": ["./*"],
            // vue-demi's exports field lacks a 'types' condition, so map it explicitly
            "vue-demi": ["../node_modules/vue-demi/lib/index.d.ts"],
        },
    },
}
