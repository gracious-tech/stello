
{
    "extends": "../tsconfig_base.jsonc",
    "compilerOptions": {
        // Electron is bundled with esbuild so use bundler resolution (no .js extension requirement)
        "lib": ["ES2020"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "types": ["node"],
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"],
}
